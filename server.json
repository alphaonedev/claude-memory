{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.alphaonedev/ai-memory",
  "description": "Persistent memory for any AI — zero token cost until recall",
  "version": "0.5.1",
  "repository": {
    "url": "https://github.com/alphaonedev/ai-memory-mcp",
    "source": "github"
  },
  "websiteUrl": "https://alphaonedev.github.io/ai-memory-mcp/",
  "packages": [
    {
      "registryType": "oci",
      "identifier": "ghcr.io/alphaonedev/ai-memory",
      "version": "0.5.1",
      "registryBaseUrl": "https://ghcr.io",
      "runtimeHint": "docker",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [],
      "packageArguments": ["mcp", "--tier", "semantic"],
      "environmentVariables": [
        {
          "name": "AI_MEMORY_DB",
          "description": "Path to the SQLite database file",
          "required": false
        }
      ]
    }
  ]
}
